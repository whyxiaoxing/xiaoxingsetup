<Window x:Class="xiaoxing打包.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:xiaoxing打包"
        mc:Ignorable="d"
        Title="小星安装程序"
        Icon="/1.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#BFF5CBD9" SizeToContent="WidthAndHeight"
        >

    <Grid Height="390" VerticalAlignment="Top" Margin="0,0,-11,0" HorizontalAlignment="Right" Width="611">

        <Frame x:Name="Frame控件" NavigationUIVisibility="Hidden"/>
        <Border x:Name="主界面" BorderThickness="1" BorderBrush="Gray" CornerRadius="4">
            <Grid Margin="-1,0,0,0" Height="393">
                <Grid.Background>
                    <ImageBrush ImageSource="/pic/logdin.png" Stretch="Uniform" Opacity="0.91" TileMode="Tile" />
                </Grid.Background>

                <Label Content="  安 装 协 议"
                       HorizontalAlignment="Left" Height="30" Margin="-8,358,0,0"
                       VerticalAlignment="Top" Width="121"
                       Cursor="Hand" FontFamily="Arial Black" FontSize="18"
                       MouseLeftButtonDown="协议事件"/>



                <Label Content=" 自 定 义 安 装"
                           Foreground="#CC000000" FontFamily="Dubai Medium"
                           FontSize="25" FontWeight="Bold"
                           Padding="0"
                           MouseLeftButtonDown="自定义安装" Background="{x:Null}" Margin="426,0,0,0" HorizontalAlignment="Left" Width="164" RenderTransformOrigin="0.445,0.478" Height="36" VerticalAlignment="Bottom" Cursor="Hand">
                    <Label.Style>
                        <Style TargetType="{x:Type Label}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#99A7F9F3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>

                <Label Content="   一   键  安  装"
                           Foreground="#CC000000" FontFamily="Dubai Medium"
                           FontSize="25" FontWeight="Bold"
                           Padding="0" Cursor="Hand"
                           MouseLeftButtonDown="一键安装" Background="{x:Null}" Margin="426,312,0,41" HorizontalAlignment="Left" RenderTransformOrigin="0.441,0.592">
                    <Label.Style>
                        <Style TargetType="{x:Type Label}">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#99A7F9F3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>

            </Grid>
        </Border>
    </Grid>
</Window>
