<Page x:Class="xiaoxing打包.自定义安装"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:xiaoxing打包"
      mc:Ignorable="d"
      Foreground="{x:Null}" Background="#77F4CAED" d:DesignHeight="389.263" d:DesignWidth="584.376">
    <Border x:Name="自定义安装xaml"  BorderThickness="1" CornerRadius="4">
        <Grid RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Width="NaN" Height="390">
            <Grid.Background>
                <ImageBrush ImageSource="/pic/logdin.png" Stretch="Uniform" Opacity="0.91" TileMode="Tile" AlignmentY="Center" AlignmentX="Center" />
            </Grid.Background>
            <Button Content="选择文件夹" HorizontalAlignment="Left" Margin="44,315,0,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" FontSize="21" FontFamily="Arial Black" ClickMode="Press"
            Click="获取路径" Cursor="Hand"    >
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FFFCB8E9"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBox HorizontalAlignment="Left" Margin="153,309,0,0" TextWrapping="Wrap" Text="{Binding M程序路径}" VerticalAlignment="Top" Background="#3FFFFFFF" BorderBrush="{x:Null}" SelectionBrush="{x:Null}" SelectionTextBrush="{x:Null}" FontSize="14" VerticalContentAlignment="Center" Cursor="Hand" FontWeight="Bold" FontStretch="ExtraCondensed" Width="299" Height="41"
                     />
            <Label Content="所需安装空间" Margin="0,32,494,331" FontSize="13" FontWeight="Bold" VerticalContentAlignment="Center" RenderTransformOrigin="1.085,0.578"/>
            <Label Content="{Binding M需要磁盘空间}" Margin="0,37,413,0" Cursor="" FontSize="14" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="0,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Top" Width="81" Height="20"/>
            <CheckBox Content="是否创建桌面快捷方式" Margin="1,52,0,306" VerticalContentAlignment="Center" FontSize="8" FontWeight="Bold" Background="#FFE0CAED" BorderBrush="{x:Null}" FontFamily="Haettenschweiler" 
                   IsChecked="{Binding M快捷键事件,Mode=TwoWay}"  Padding="3,0,0,0" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left"  >
                <CheckBox.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="0.21"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </CheckBox.RenderTransform>
                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="1.6" ScaleY="1.6"></ScaleTransform>
                </CheckBox.LayoutTransform>
            </CheckBox>
            <Button Content="开始安装" Margin="491,350,11,12" BorderBrush="{x:Null}" Background="{x:Null}" FontWeight="Bold" FontSize="19" Click="开始安装"/>
            <Button Content="上一步" Margin="0,357,521,0" VerticalAlignment="Top" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="19" RenderTransformOrigin="0.577,-0.345"
                    Click="上一步"/>
            <Button Content="点击我显示安装内容" Margin="0,10,452,358" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalContentAlignment="Left" FontSize="14" FontWeight="Bold" Cursor="Hand"
                 Click="安装信息"   />
        </Grid>
    </Border>
</Page>
